generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String          @id @default(cuid())
  clerkId       String          @unique
  email         String          @unique
  name          String?
  dateOfBirth   DateTime?
  country       String?
  zipCode       String?
  imageUrl      String?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  savedEvents   SavedEvent[]
  priceAlerts   PriceAlert[]
  searchHistory SearchHistory[]

  @@index([clerkId])
}

model SavedEvent {
  id          String   @id @default(cuid())
  userId      String
  eventId     String
  eventName   String
  eventDate   DateTime
  venue       String
  homeTeam    String?
  awayTeam    String?
  sport       String
  lowestPrice Float?
  imageUrl    String?
  createdAt   DateTime @default(now())

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, eventId])
  @@index([userId])
}

model PriceAlert {
  id          String    @id @default(cuid())
  userId      String
  eventId     String
  eventName   String
  targetPrice Float
  platform    String?
  isActive    Boolean   @default(true)
  triggeredAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([eventId, isActive])
}

model SearchHistory {
  id          String   @id @default(cuid())
  userId      String
  query       String
  sport       String?
  resultCount Int?
  createdAt   DateTime @default(now())

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model CachedEvent {
  id            String   @id
  externalIds   Json
  name          String
  sport         String
  league        String?
  homeTeam      String?
  awayTeam      String?
  venue         String
  city          String
  state         String?
  country       String
  eventDate     DateTime
  imageUrl      String?
  lowestPrice   Float?
  ticketCount   Int?
  lastFetchedAt DateTime
  createdAt     DateTime @default(now())

  @@index([sport, eventDate])
  @@index([eventDate])
}
